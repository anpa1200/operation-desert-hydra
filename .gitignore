# ── Secrets ────────────────────────────────────────────────────────────────────
stack/.env
stack/.env.*
!stack/.env.template

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.venv/
venv/

# ── Docusaurus site ────────────────────────────────────────────────────────────
docs-site/node_modules/
docs-site/build/
docs-site/.docusaurus/

# ── OS / editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Lab VM (Vagrant state — see lab/.gitignore too) ────────────────────────────
lab/.vagrant/
*.dmp

# ── Raw source acquisition artifacts (headers + raw HTML are not useful to consumers)
# Keep: source.txt, source.pdf, metadata.json, fallback-reader.txt
docs/source-gathering/raw-sources/**/headers.txt
docs/source-gathering/raw-sources/**/source.html

# ── Internal working documents (planning, analysis, superseded scripts) ─────────
ai/
docs/00-*.md
docs/08-*.md
docs/article-step-0-project-scenario.md
lab/scripts/
opencti/

# ── Empty stub directories ─────────────────────────────────────────────────────
# (these exist for future work but contain nothing deployable)
lab/email-simulation/
lab/powershell-simulation/
lab/rmm-simulation/
lab/telemetry/
lab/windows-ad/

# ── Forensic / sensitive artifacts ─────────────────────────────────────────────
*.evtx
*.pcap
*.sqlite
*.db
*.log
