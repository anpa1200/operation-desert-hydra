# Operation Desert Hydra — Stack Environment Template
# Copy to .env and fill in values before running start.sh
# cp stack/.env.template stack/.env

# ── OpenCTI ───────────────────────────────────────────────────────────────────
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_ADMIN_EMAIL=admin@opencti.local

# Generate with: openssl rand -hex 32
OPENCTI_ADMIN_PASSWORD=CHANGE_ME_32_CHAR_HEX
OPENCTI_ADMIN_TOKEN=CHANGE_ME_UUID4

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# This password is also used by Winlogbeat on the lab VM to ship logs.
# Must be set before starting the lab: export ELASTICSEARCH_PASSWORD=<value>
ELASTIC_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=opencti

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=CHANGE_ME_STRONG_PASSWORD

# ── Kibana service account token ──────────────────────────────────────────────
# Generate after first ES start:
#   curl -s -u elastic:$ELASTIC_PASSWORD -X POST \
#     http://localhost:9200/_security/service/elastic/kibana/credential/token/kibana_lab_token
# Then paste the token value below:
KIBANA_SERVICE_ACCOUNT_TOKEN=CHANGE_ME_TOKEN
